{
  "name": "elite-v1",
  "version": "1.0.0",
  "private": true,
  "description": "Elite v1 — unified commerce + operations super-app for Newtech (newtechq8.com)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --linked > packages/types/src/database.types.ts",
    "db:seed": "supabase db execute --file supabase/seed.sql"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0"
  }
}
