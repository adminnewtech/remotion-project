# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server / edge functions only — never expose to clients
SUPABASE_PROJECT_REF=

# Expo public (mobile)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Maps ──────────────────────────────────────────────────
NEXT_PUBLIC_MAPS_API_KEY=
EXPO_PUBLIC_MAPS_API_KEY=

# ── Payments (Kuwait) ─────────────────────────────────────
PAYMENT_GATEWAY=myfatoorah          # myfatoorah | tap
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# ── Integrations ──────────────────────────────────────────
ZOHO_BOOKS_ORG_ID=
ZOHO_BOOKS_TOKEN=
ZOHO_DESK_ORG_ID=
ZOHO_DESK_TOKEN=
GMAIL_OAUTH_REFRESH_TOKEN=
META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=
META_CATALOG_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_IMAGES_HASH=

# ── Push notifications ────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ── Edge Functions runtime (set via `supabase secrets set`) ─
SUPABASE_URL=                       # service-side Supabase URL (edge functions)
SUPABASE_ANON_KEY=
SUPABASE_FUNCTIONS_URL=             # base URL for function-to-function invokes
ALLOWED_ORIGIN=*                    # CORS allow-origin for functions
PAYMENT_RETURN_URL=                 # gateway redirect-back URL after payment
GMAIL_RELAY_URL=                    # email relay endpoint used by notify()
GMAIL_RELAY_KEY=
